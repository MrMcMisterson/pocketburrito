---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'PocketBurrito — your pocket-sized guide to the best tech deals and product recommendations.' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title} | PocketBurrito</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-[#0f0f0f] text-gray-100 font-sans antialiased min-h-screen flex flex-col">
    <!-- Navigation -->
    <header class="sticky top-0 z-50 bg-[#0f0f0f]/90 backdrop-blur-sm border-b border-[#2a2a2a]">
      <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-2 group">
            <span class="text-2xl">🌯</span>
            <span class="text-xl font-bold text-white group-hover:text-orange-500 transition-colors duration-200">
              Pocket<span class="text-orange-500">Burrito</span>
            </span>
          </a>

          <!-- Desktop nav links -->
          <div class="hidden sm:flex items-center gap-1">
            <a
              href="/"
              class="px-4 py-2 rounded-lg text-sm font-medium text-gray-300 hover:text-white hover:bg-[#1a1a1a] transition-all duration-200"
            >
              Home
            </a>
            <a
              href="/deals"
              class="px-4 py-2 rounded-lg text-sm font-medium text-gray-300 hover:text-white hover:bg-[#1a1a1a] transition-all duration-200"
            >
              Deals
            </a>
            <a
              href="/about"
              class="px-4 py-2 rounded-lg text-sm font-medium text-gray-300 hover:text-white hover:bg-[#1a1a1a] transition-all duration-200"
            >
              About
            </a>
            <a
              href="/deals"
              class="ml-3 px-4 py-2 rounded-lg text-sm font-semibold bg-orange-500 hover:bg-orange-600 text-white transition-all duration-200"
            >
              Browse Deals
            </a>
          </div>

          <!-- Mobile hamburger -->
          <label for="mobile-menu-toggle" class="sm:hidden cursor-pointer p-2 rounded-lg hover:bg-[#1a1a1a] transition-colors">
            <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </label>
        </div>

        <!-- Mobile menu -->
        <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
        <div class="hidden peer-checked:flex flex-col pb-4 gap-1 sm:hidden">
          <a href="/" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-300 hover:text-white hover:bg-[#1a1a1a] transition-all">Home</a>
          <a href="/deals" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-300 hover:text-white hover:bg-[#1a1a1a] transition-all">Deals</a>
          <a href="/about" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-300 hover:text-white hover:bg-[#1a1a1a] transition-all">About</a>
          <a href="/deals" class="px-4 py-2 rounded-lg text-sm font-semibold bg-orange-500 hover:bg-orange-600 text-white text-center transition-all">Browse Deals</a>
        </div>
      </nav>
    </header>

    <!-- Page content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[#2a2a2a] bg-[#080808] mt-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-8">
          <!-- Brand -->
          <div>
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xl">🌯</span>
              <span class="text-lg font-bold text-white">Pocket<span class="text-orange-500">Burrito</span></span>
            </div>
            <p class="text-sm text-gray-400 leading-relaxed">
              Your pocket-sized guide to the best tech deals, gadgets, and product recommendations on Amazon.ca.
            </p>
          </div>

          <!-- Links -->
          <div>
            <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">Quick Links</h3>
            <ul class="space-y-2">
              <li><a href="/" class="text-sm text-gray-400 hover:text-orange-500 transition-colors">Home</a></li>
              <li><a href="/deals" class="text-sm text-gray-400 hover:text-orange-500 transition-colors">All Deals</a></li>
              <li><a href="/about" class="text-sm text-gray-400 hover:text-orange-500 transition-colors">About</a></li>
              <li><a href="/privacy" class="text-sm text-gray-400 hover:text-orange-500 transition-colors">Privacy Policy</a></li>
            </ul>
          </div>

          <!-- Categories -->
          <div>
            <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">Categories</h3>
            <ul class="space-y-2">
              <li><a href="/deals?category=Gadgets" class="text-sm text-gray-400 hover:text-orange-500 transition-colors">Gadgets</a></li>
              <li><a href="/deals?category=Audio" class="text-sm text-gray-400 hover:text-orange-500 transition-colors">Audio</a></li>
              <li><a href="/deals?category=Smart+Home" class="text-sm text-gray-400 hover:text-orange-500 transition-colors">Smart Home</a></li>
              <li><a href="/deals?category=Accessories" class="text-sm text-gray-400 hover:text-orange-500 transition-colors">Accessories</a></li>
            </ul>
          </div>
        </div>

        <!-- Affiliate disclosure -->
        <div class="border-t border-[#2a2a2a] pt-6">
          <p class="text-xs text-gray-500 text-center leading-relaxed max-w-2xl mx-auto">
            <strong class="text-gray-400">Affiliate Disclosure:</strong> As an Amazon Associate, PocketBurrito earns from qualifying purchases. Prices are accurate at the time of publication and subject to change. We only recommend products we genuinely believe provide value.
          </p>
          <p class="text-xs text-gray-600 text-center mt-3">
            &copy; {new Date().getFullYear()} PocketBurrito. All rights reserved.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
