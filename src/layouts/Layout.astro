---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Premium game server hosting with instant setup, DDoS protection, and 24/7 support. Host Minecraft, Valheim, Terraria, and more." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Rajdhani:wght@600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-gaming-darker text-gray-100 font-sans">
    <!-- Navigation -->
    <nav class="fixed w-full z-50 bg-gaming-dark/95 backdrop-blur-sm border-b border-gray-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex items-center">
            <a href="/" class="flex items-center space-x-2">
              <img src="/logo.png" alt="Pocket Burrito Logo" class="h-20 w-auto rounded-lg" />
              <span class="text-xl font-gaming font-bold bg-gradient-to-r from-gaming-accent to-gaming-purple bg-clip-text text-transparent">
                PocketBurrito
              </span>
            </a>
          </div>
          
          <div class="hidden md:flex items-center space-x-8">
            <a href="/" class="text-gray-300 hover:text-white transition">Home</a>
            <a href="/games" class="text-gray-300 hover:text-white transition">Games</a>
            <a href="/pricing" class="text-gray-300 hover:text-white transition">Pricing</a>
            <a href="/docs" class="text-gray-300 hover:text-white transition">Docs</a>
            <a href="https://panel.pocketburrito.ca" class="text-gray-300 hover:text-white transition">Panel Login</a>
            <a href="/games" class="bg-gradient-to-r from-gaming-accent to-gaming-purple text-white px-6 py-2 rounded-lg font-semibold hover:shadow-lg hover:shadow-gaming-accent/50 transition">
              Order Now
            </a>
          </div>

          <!-- Mobile menu button -->
          <div class="md:hidden">
            <button id="mobile-menu-btn" class="text-gray-300 hover:text-white">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden bg-gaming-dark border-t border-gray-800">
        <div class="px-4 py-4 space-y-3">
          <a href="/" class="block text-gray-300 hover:text-white transition">Home</a>
          <a href="/games" class="block text-gray-300 hover:text-white transition">Games</a>
          <a href="/pricing" class="block text-gray-300 hover:text-white transition">Pricing</a>
          <a href="/docs" class="block text-gray-300 hover:text-white transition">Docs</a>
          <a href="https://panel.pocketburrito.ca" class="block text-gray-300 hover:text-white transition">Panel Login</a>
          <a href="/games" class="block bg-gradient-to-r from-gaming-accent to-gaming-purple text-white px-6 py-2 rounded-lg font-semibold text-center">
            Order Now
          </a>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gaming-dark border-t border-gray-800 mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div class="col-span-1 md:col-span-2">
            <div class="flex items-center space-x-2 mb-4">
              <img src="/logo.png" alt="Pocket Burrito Logo" class="w-60 h-40 rounded-lg" />  
              <span class="text-xl font-gaming font-bold">PocketBurrito</span>
            </div>
            <p class="text-gray-400 mb-4">
              Premium game server hosting with instant setup, DDoS protection, and 24/7 support.
            </p>
            <div class="flex space-x-4">
              <a href="https://discord.gg/gjjGWYY7" class="text-gray-400 hover:text-white transition" aria-label="Discord">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028 14.09 14.09 0 001.226-1.994.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
              </a>
            </div>
          </div>

          <div>
            <h3 class="font-semibold text-white mb-4">Quick Links</h3>
            <ul class="space-y-2">
              <li><a href="/games" class="text-gray-400 hover:text-white transition">Game Servers</a></li>
              <li><a href="/pricing" class="text-gray-400 hover:text-white transition">Pricing</a></li>
              <li><a href="/docs" class="text-gray-400 hover:text-white transition">Documentation</a></li>
              <li><a href="https://billing.pocketburrito.ca" class="text-gray-400 hover:text-white transition">Client Area</a></li>
            </ul>
          </div>

          <div>
            <h3 class="font-semibold text-white mb-4">Legal</h3>
            <ul class="space-y-2">
              <li><a href="/terms" class="text-gray-400 hover:text-white transition">Terms of Service</a></li>
              <li><a href="/privacy" class="text-gray-400 hover:text-white transition">Privacy Policy</a></li>
              <li><a href="/refund" class="text-gray-400 hover:text-white transition">Refund Policy</a></li>
            </ul>
          </div>
        </div>

        <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-400">
          <p>&copy; 2026 PocketBurrito. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      
      mobileMenuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
