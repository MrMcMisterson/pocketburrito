---
import Layout from '../layouts/Layout.astro';
import { allGames } from '../data/games';
import { gameWiki } from '../data/gameWiki';

const gamesWithGuides = allGames.filter(game => gameWiki[game.slug]);
---

<Layout title="Documentation - PocketBurrito" description="Learn how to set up and manage your game server with our comprehensive guides.">
  <!-- Header -->
  <section class="bg-gradient-to-b from-gaming-dark to-gaming-darker py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-6xl font-gaming font-bold text-white mb-4">
        Documentation
      </h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        Everything you need to know about managing your game server
      </p>
    </div>
  </section>

  <!-- Getting Started -->
  <section class="py-16 bg-gaming-darker">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-gaming font-bold text-white mb-8">Getting Started</h2>

      <div class="space-y-8">
        <!-- Step 1 -->
        <div class="bg-gaming-dark border border-gray-800 rounded-lg p-6">
          <div class="flex items-start space-x-4">
            <div class="w-10 h-10 bg-gradient-to-br from-gaming-accent to-gaming-purple rounded-full flex items-center justify-center flex-shrink-0">
              <span class="text-white font-bold">1</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-white mb-2">Order Your Server</h3>
              <p class="text-gray-400 mb-4">
                Choose your game and plan from our pricing page. Complete checkout with your preferred payment method.
              </p>
              <a href="/pricing" class="text-gaming-accent hover:text-gaming-purple transition">
                View Pricing →
              </a>
            </div>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="bg-gaming-dark border border-gray-800 rounded-lg p-6">
          <div class="flex items-start space-x-4">
            <div class="w-10 h-10 bg-gradient-to-br from-gaming-purple to-gaming-pink rounded-full flex items-center justify-center flex-shrink-0">
              <span class="text-white font-bold">2</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-white mb-2">Access Your Panel</h3>
              <p class="text-gray-400 mb-4">
                You'll receive an email with your server details and login credentials. Access your control panel at panel.pocketburrito.ca
              </p>
              <a href="https://panel.pocketburrito.ca" class="text-gaming-purple hover:text-gaming-pink transition">
                Go to Panel →
              </a>
            </div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="bg-gaming-dark border border-gray-800 rounded-lg p-6">
          <div class="flex items-start space-x-4">
            <div class="w-10 h-10 bg-gradient-to-br from-gaming-pink to-gaming-accent rounded-full flex items-center justify-center flex-shrink-0">
              <span class="text-white font-bold">3</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-white mb-2">Start Your Server</h3>
              <p class="text-gray-400 mb-4">
                Your server is automatically configured and ready to start. Click the "Start" button in your control panel and you're live!
              </p>
            </div>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="bg-gaming-dark border border-gray-800 rounded-lg p-6">
          <div class="flex items-start space-x-4">
            <div class="w-10 h-10 bg-gradient-to-br from-gaming-accent to-gaming-purple rounded-full flex items-center justify-center flex-shrink-0">
              <span class="text-white font-bold">4</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-white mb-2">Connect & Play</h3>
              <p class="text-gray-400">
                Use the server IP address shown in your panel to connect from your game. Share it with friends and start playing!
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Game Guides -->
  <section class="py-16 bg-gaming-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-gaming font-bold text-white mb-4">Game Guides</h2>
      <p class="text-gray-400 mb-8">Detailed setup instructions, configuration, and troubleshooting for each game we host.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {gamesWithGuides.map(game => (
          <a href={`/docs/${game.slug}`} class="bg-gaming-darker border border-gray-800 rounded-lg p-6 hover:border-gaming-accent transition group">
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-gaming-accent transition">{game.name}</h3>
            <p class="text-gray-400 text-sm mb-4 line-clamp-2">{game.description}</p>
            <span class="text-gaming-accent text-sm font-medium group-hover:text-gaming-purple transition">
              View Guide →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Common Tasks -->
  <section class="py-16 bg-gaming-darker">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-gaming font-bold text-white mb-8">Common Tasks</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gaming-dark border border-gray-800 rounded-lg p-6 hover:border-gaming-accent transition">
          <h3 class="text-lg font-semibold text-white mb-2">Installing Mods</h3>
          <p class="text-gray-400 mb-4">
            Upload mod files via the File Manager or use one-click installers for popular modpacks.
          </p>
        </div>

        <div class="bg-gaming-dark border border-gray-800 rounded-lg p-6 hover:border-gaming-accent transition">
          <h3 class="text-lg font-semibold text-white mb-2">Managing Backups</h3>
          <p class="text-gray-400 mb-4">
            Automatic daily backups are created. Restore or download backups from the Backups tab.
          </p>
        </div>

        <div class="bg-gaming-dark border border-gray-800 rounded-lg p-6 hover:border-gaming-accent transition">
          <h3 class="text-lg font-semibold text-white mb-2">Editing Config Files</h3>
          <p class="text-gray-400 mb-4">
            Use the built-in text editor in File Manager to modify server configuration files.
          </p>
        </div>

        <div class="bg-gaming-dark border border-gray-800 rounded-lg p-6 hover:border-gaming-accent transition">
          <h3 class="text-lg font-semibold text-white mb-2">Adding Admins</h3>
          <p class="text-gray-400 mb-4">
            Grant sub-users access to your server from the Users tab in the control panel.
          </p>
        </div>

        <div class="bg-gaming-dark border border-gray-800 rounded-lg p-6 hover:border-gaming-accent transition">
          <h3 class="text-lg font-semibold text-white mb-2">Viewing Console</h3>
          <p class="text-gray-400 mb-4">
            Monitor server output and send commands via the Console tab in real-time.
          </p>
        </div>

        <div class="bg-gaming-dark border border-gray-800 rounded-lg p-6 hover:border-gaming-accent transition">
          <h3 class="text-lg font-semibold text-white mb-2">Changing Server Settings</h3>
          <p class="text-gray-400 mb-4">
            Adjust RAM allocation, port numbers, and startup parameters from the Settings tab.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Troubleshooting -->
  <section class="py-16 bg-gaming-darker">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-gaming font-bold text-white mb-8">Troubleshooting</h2>

      <div class="space-y-4">
        <details class="bg-gaming-dark border border-gray-800 rounded-lg p-6">
          <summary class="text-lg font-semibold text-white cursor-pointer">Server won't start</summary>
          <p class="text-gray-400 mt-4">
            Check the console for error messages. Common causes include invalid configuration files or insufficient RAM. 
            Try restoring from a backup or contact support for assistance.
          </p>
        </details>

        <details class="bg-gaming-dark border border-gray-800 rounded-lg p-6">
          <summary class="text-lg font-semibold text-white cursor-pointer">Can't connect to server</summary>
          <p class="text-gray-400 mt-4">
            Verify the server is running in your panel. Check that you're using the correct IP address and port. 
            Ensure your game version matches the server version.
          </p>
        </details>

        <details class="bg-gaming-dark border border-gray-800 rounded-lg p-6">
          <summary class="text-lg font-semibold text-white cursor-pointer">Mods not loading</summary>
          <p class="text-gray-400 mt-4">
            Ensure mods are in the correct folder and compatible with your game version. Check console for mod loading errors. 
            Restart the server after adding mods.
          </p>
        </details>

        <details class="bg-gaming-dark border border-gray-800 rounded-lg p-6">
          <summary class="text-lg font-semibold text-white cursor-pointer">Server is lagging</summary>
          <p class="text-gray-400 mt-4">
            Check server resource usage in your panel. You may need to upgrade to a higher RAM plan. 
            Reduce view distance or installed mods to improve performance.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Support -->
  <section class="py-16 bg-gaming-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-gaming font-bold text-white mb-4">Need More Help?</h2>
      <p class="text-xl text-gray-400 mb-8">
        Our support team is available 24/7 to assist you
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://discord.gg/gjjGWYY7" class="bg-gradient-to-r from-gaming-accent to-gaming-purple text-white px-8 py-3 rounded-lg font-semibold hover:shadow-xl transition">
          Join Discord
        </a>
        <a href="https://billing.pocketburrito.ca/tickets/create" class="bg-white/10 text-white px-8 py-3 rounded-lg font-semibold border border-white/20 hover:bg-white/20 transition">
          Open Ticket
        </a>
      </div>
    </div>
  </section>
</Layout>
