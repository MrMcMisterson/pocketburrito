---
import Layout from '../../layouts/Layout.astro';
import { allGames } from '../../data/games';
import { gameWiki } from '../../data/gameWiki';

export async function getStaticPaths() {
  return allGames
    .filter(game => gameWiki[game.slug])
    .map(game => ({
      params: { slug: game.slug },
      props: { game, wiki: gameWiki[game.slug] },
    }));
}

const { game, wiki } = Astro.props;
---

<Layout title={`${game.name} Server Guide - PocketBurrito`} description={`Complete guide to setting up and managing your ${game.name} dedicated server. Connection instructions, configuration, FAQ, and troubleshooting.`}>
  <!-- Header -->
  <section class="bg-gradient-to-b from-gaming-dark to-gaming-darker py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/docs" class="text-gaming-accent hover:text-gaming-purple transition text-sm mb-4 inline-block">
        ← Back to Documentation
      </a>
      <h1 class="text-4xl sm:text-6xl font-gaming font-bold text-white mb-4">
        {game.name} Server Guide
      </h1>
      <p class="text-xl text-gray-300 max-w-3xl">
        {game.description}
      </p>
    </div>
  </section>

  <!-- How to Connect -->
  <section class="py-16 bg-gaming-darker">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-gaming font-bold text-white mb-8">How to Connect</h2>

      <div class="space-y-6">
        {wiki.connectionSteps.map((step, index) => (
          <div class="bg-gaming-dark border border-gray-800 rounded-lg p-6">
            <div class="flex items-start space-x-4">
              <div class="w-10 h-10 bg-gradient-to-br from-gaming-accent to-gaming-purple rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-white font-bold">{index + 1}</span>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-white mb-2">{step.title}</h3>
                <p class="text-gray-400">{step.detail}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Server Configuration -->
  <section class="py-16 bg-gaming-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-gaming font-bold text-white mb-8">Server Configuration</h2>

      {wiki.configFiles.map(config => (
        <div class="mb-8">
          <h3 class="text-xl font-semibold text-white mb-4">
            <code class="bg-gaming-darker px-3 py-1 rounded text-gaming-accent text-lg">{config.file}</code>
          </h3>
          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead>
                <tr class="border-b border-gray-800">
                  <th class="py-3 px-4 text-gray-300 font-semibold">Setting</th>
                  <th class="py-3 px-4 text-gray-300 font-semibold">Description</th>
                  <th class="py-3 px-4 text-gray-300 font-semibold">Default</th>
                </tr>
              </thead>
              <tbody>
                {config.settings.map(setting => (
                  <tr class="border-b border-gray-800/50">
                    <td class="py-3 px-4">
                      <code class="text-gaming-accent text-sm">{setting.name}</code>
                    </td>
                    <td class="py-3 px-4 text-gray-400 text-sm">{setting.description}</td>
                    <td class="py-3 px-4">
                      <code class="text-gray-300 text-sm">{setting.default}</code>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Admin Commands (conditional) -->
  {wiki.adminCommands && wiki.adminCommands.length > 0 && (
    <section class="py-16 bg-gaming-darker">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-gaming font-bold text-white mb-8">Admin Commands</h2>

        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="border-b border-gray-800">
                <th class="py-3 px-4 text-gray-300 font-semibold">Command</th>
                <th class="py-3 px-4 text-gray-300 font-semibold">Description</th>
              </tr>
            </thead>
            <tbody>
              {wiki.adminCommands.map(cmd => (
                <tr class="border-b border-gray-800/50">
                  <td class="py-3 px-4">
                    <code class="bg-gaming-dark px-2 py-1 rounded text-gaming-accent text-sm">{cmd.command}</code>
                  </td>
                  <td class="py-3 px-4 text-gray-400 text-sm">{cmd.description}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  <!-- Mod Support (conditional) -->
  {wiki.modSupport && (
    <section class={`py-16 ${wiki.adminCommands && wiki.adminCommands.length > 0 ? 'bg-gaming-dark' : 'bg-gaming-darker'}`}>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-gaming font-bold text-white mb-8">Mod Support</h2>

        <div class="bg-gaming-darker border border-gray-800 rounded-lg p-6">
          <p class="text-gray-300 leading-relaxed">{wiki.modSupport}</p>
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  <section class="py-16 bg-gaming-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-gaming font-bold text-white mb-8">Frequently Asked Questions</h2>

      <div class="space-y-4">
        {wiki.faq.map(item => (
          <details class="bg-gaming-darker border border-gray-800 rounded-lg p-6 group">
            <summary class="text-lg font-semibold text-white cursor-pointer list-none flex items-center justify-between">
              <span>{item.question}</span>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="text-gray-400 mt-4">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Troubleshooting -->
  <section class="py-16 bg-gaming-darker">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-gaming font-bold text-white mb-8">Troubleshooting</h2>

      <div class="space-y-4">
        {wiki.troubleshooting.map(item => (
          <details class="bg-gaming-dark border border-gray-800 rounded-lg p-6 group">
            <summary class="text-lg font-semibold text-white cursor-pointer list-none flex items-center justify-between">
              <span>{item.problem}</span>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="text-gray-400 mt-4">{item.solution}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Support CTA -->
  <section class="py-16 bg-gaming-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-gaming font-bold text-white mb-4">Still Need Help?</h2>
      <p class="text-xl text-gray-400 mb-8">
        Our support team is available 24/7 to help with your {game.name} server
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://discord.gg/gjjGWYY7" class="bg-gradient-to-r from-gaming-accent to-gaming-purple text-white px-8 py-3 rounded-lg font-semibold hover:shadow-xl transition">
          Join Discord
        </a>
        <a href="https://billing.pocketburrito.ca/tickets/create" class="bg-white/10 text-white px-8 py-3 rounded-lg font-semibold border border-white/20 hover:bg-white/20 transition">
          Open Ticket
        </a>
      </div>
    </div>
  </section>
</Layout>
