---
import Layout from '../layouts/Layout.astro';
import { lightTierGames, mediumTierGames } from '../data/games';
---

<Layout title="Game Servers - PocketBurrito" description="Browse all available game servers. Host Minecraft, Valheim, Terraria, Factorio, and 12+ more games.">
  <!-- Header -->
  <section class="bg-gradient-to-b from-gaming-dark to-gaming-darker py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl sm:text-6xl font-gaming font-bold text-white mb-4 text-center">
        Game Servers
      </h1>
      <p class="text-xl text-gray-300 text-center max-w-3xl mx-auto">
        Choose from 15+ popular multiplayer games. All servers include DDoS protection, daily backups, and instant setup.
      </p>
    </div>
  </section>

  <!-- Light Tier Games -->
  <section class="py-16 bg-gaming-darker">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h2 class="text-3xl font-gaming font-bold text-white mb-2">Light Tier Games</h2>
        <p class="text-gray-400">Perfect for small groups and lower resource requirements</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {lightTierGames.map(game => (
          <a href={`/games/${game.slug}`} class="group bg-gaming-dark border border-gray-800 rounded-xl overflow-hidden hover:border-gaming-accent transition-all hover:shadow-xl hover:shadow-gaming-accent/20">
            <div class="relative h-40 overflow-hidden">
              <img 
                src={game.imageUrl} 
                alt={game.name}
                class="w-full h-full object-cover group-hover:scale-110 transition duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-gaming-dark to-transparent"></div>
            </div>
            <div class="p-5">
              <h3 class="text-xl font-gaming font-bold text-white mb-2">{game.name}</h3>
              <div class="flex items-center justify-between mb-3">
                <span class="text-sm text-gray-400">Up to {game.tiers?.[0]?.players ?? game.maxPlayers} players</span>
                <span class="text-sm text-gray-400">{game.tiers?.[0]?.ram ?? game.ram} RAM</span>
              </div>
              <div class="flex items-baseline justify-between">
                <div>
                  <span class="text-2xl font-bold text-white">${game.tiers?.[0]?.price ?? game.price}</span>
                  <span class="text-gray-400 text-sm">/mo</span>
                </div>
                <span class="text-gaming-accent text-sm group-hover:translate-x-1 transition">
                  Details →
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Medium Tier Games -->
  <section class="py-16 bg-gaming-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h2 class="text-3xl font-gaming font-bold text-white mb-2">Medium Tier Games</h2>
        <p class="text-gray-400">Popular games with multiple pricing tiers and player counts</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {mediumTierGames.map(game => (
          <a href={`/games/${game.slug}`} class="group bg-gaming-darker border border-gray-800 rounded-xl overflow-hidden hover:border-gaming-purple transition-all hover:shadow-xl hover:shadow-gaming-purple/20">
            <div class="relative h-48 overflow-hidden">
              <img 
                src={game.imageUrl} 
                alt={game.name}
                class="w-full h-full object-cover group-hover:scale-110 transition duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-gaming-darker to-transparent"></div>
              {game.tiers && game.tiers.length > 1 && (
                <div class="absolute top-4 right-4 bg-gaming-accent px-3 py-1 rounded-full text-xs font-semibold text-white">
                  {game.tiers.length} Plans
                </div>
              )}
            </div>
            <div class="p-6">
              <h3 class="text-2xl font-gaming font-bold text-white mb-2">{game.name}</h3>
              <p class="text-gray-400 text-sm mb-4 line-clamp-2">{game.description}</p>
              
              {game.tiers ? (
                <div class="space-y-2 mb-4">
                  <div class="text-sm text-gray-400">Starting from:</div>
                  <div class="flex items-baseline">
                    <span class="text-2xl font-bold text-white">${game.tiers[0].price}</span>
                    <span class="text-gray-400 text-sm ml-1">/month</span>
                  </div>
                  <div class="text-sm text-gray-500">
                    {game.tiers[0].players} players • {game.tiers[0].ram}
                  </div>
                </div>
              ) : (
                <div class="flex items-baseline justify-between mb-4">
                  <div>
                    <span class="text-2xl font-bold text-white">${game.price}</span>
                    <span class="text-gray-400 text-sm">/mo</span>
                  </div>
                  <span class="text-sm text-gray-400">{game.maxPlayers} players</span>
                </div>
              )}
              
              <span class="text-gaming-purple text-sm group-hover:translate-x-1 transition inline-block">
                View All Plans →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-gaming-accent to-gaming-purple">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-gaming font-bold text-white mb-4">
        Can't Find Your Game?
      </h2>
      <p class="text-lg text-white/90 mb-8">
        We're constantly adding new games. Contact us to request a game server!
      </p>
      <a href="https://billing.pocketburrito.ca/tickets/create" class="inline-block bg-white text-gaming-accent px-8 py-3 rounded-lg font-semibold hover:shadow-xl transition">
        Contact Support
      </a>
    </div>
  </section>
</Layout>
