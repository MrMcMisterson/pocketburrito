---
import Layout from '../../layouts/Layout.astro';
import { allGames } from '../../data/games';

export async function getStaticPaths() {
  return allGames.map(game => ({
    params: { slug: game.slug },
    props: { game },
  }));
}

const { game } = Astro.props;
const hasMultipleTiers = game.tiers && game.tiers.length > 1;
---

<Layout title={`${game.name} Server Hosting - PocketBurrito`} description={`Host your own ${game.name} server. ${game.description}`}>
  <!-- Hero Section -->
  <section class="relative h-96 overflow-hidden">
    <img 
      src={game.imageUrl} 
      alt={game.name}
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-gaming-darker via-gaming-darker/80 to-gaming-darker/40"></div>
    
    <div class="absolute inset-0 flex items-end">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 w-full">
        <h1 class="text-4xl sm:text-6xl font-gaming font-bold text-white mb-4">
          {game.name} Server Hosting
        </h1>
        <p class="text-xl text-gray-200 max-w-3xl">
          {game.description}
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-16 bg-gaming-darker">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-gaming font-bold text-white mb-12 text-center">
        Choose Your Plan
      </h2>

      {hasMultipleTiers ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {game.tiers.map((tier, index) => (
            <div class={`bg-gaming-dark border rounded-xl p-6 ${
              index === 1 ? 'border-gaming-accent shadow-xl shadow-gaming-accent/20 scale-105' : 'border-gray-800'
            }`}>
              {index === 1 && (
                <div class="bg-gaming-accent text-white text-xs font-semibold px-3 py-1 rounded-full inline-block mb-4">
                  POPULAR
                </div>
              )}
              <div class="mb-4">
                <div class="text-3xl font-bold text-white mb-1">${tier.price}</div>
                <div class="text-gray-400 text-sm">per month</div>
              </div>
              
              <div class="space-y-3 mb-6">
                <div class="flex items-center text-gray-300">
                  <svg class="w-5 h-5 text-gaming-accent mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{tier.players} Players</span>
                </div>
                <div class="flex items-center text-gray-300">
                  <svg class="w-5 h-5 text-gaming-accent mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{tier.ram} RAM</span>
                </div>
                <div class="flex items-center text-gray-300">
                  <svg class="w-5 h-5 text-gaming-accent mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>DDoS Protection</span>
                </div>
                <div class="flex items-center text-gray-300">
                  <svg class="w-5 h-5 text-gaming-accent mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Daily Backups</span>
                </div>
              </div>

              <a href={`https://billing.pocketburrito.ca/order/${game.slug}-${tier.ram.toLowerCase()}`} 
                 class={`block text-center py-3 px-6 rounded-lg font-semibold transition ${
                   index === 1 
                     ? 'bg-gradient-to-r from-gaming-accent to-gaming-purple text-white hover:shadow-xl' 
                     : 'bg-white/10 text-white hover:bg-white/20'
                 }`}>
                Order Now
              </a>
            </div>
          ))}
        </div>
      ) : (
        <div class="max-w-md mx-auto">
          <div class="bg-gaming-dark border-2 border-gaming-accent rounded-xl p-8 shadow-xl shadow-gaming-accent/20">
            <div class="bg-gaming-accent text-white text-xs font-semibold px-3 py-1 rounded-full inline-block mb-4">
              BEST VALUE
            </div>
            <div class="mb-6">
              <div class="text-5xl font-bold text-white mb-2">${game.price}</div>
              <div class="text-gray-400">per month</div>
            </div>
            
            <div class="space-y-3 mb-8">
              <div class="flex items-center text-gray-300">
                <svg class="w-5 h-5 text-gaming-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Up to {game.maxPlayers} Players</span>
              </div>
              <div class="flex items-center text-gray-300">
                <svg class="w-5 h-5 text-gaming-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{game.ram} RAM</span>
              </div>
              <div class="flex items-center text-gray-300">
                <svg class="w-5 h-5 text-gaming-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>DDoS Protection</span>
              </div>
              <div class="flex items-center text-gray-300">
                <svg class="w-5 h-5 text-gaming-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Daily Automated Backups</span>
              </div>
              <div class="flex items-center text-gray-300">
                <svg class="w-5 h-5 text-gaming-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>24/7 Support</span>
              </div>
            </div>

            <a href={`https://billing.pocketburrito.ca/order/${game.slug}`} 
               class="block text-center bg-gradient-to-r from-gaming-accent to-gaming-purple text-white py-4 px-8 rounded-lg font-bold text-lg hover:shadow-2xl hover:shadow-gaming-accent/50 transition">
              Order Your Server
            </a>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 bg-gaming-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-gaming font-bold text-white mb-12 text-center">
        What's Included
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {game.features?.map(feature => (
          <div class="bg-gaming-darker border border-gray-800 rounded-lg p-6">
            <div class="flex items-start">
              <svg class="w-6 h-6 text-gaming-accent mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <div>
                <h3 class="text-lg font-semibold text-white mb-1">{feature}</h3>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Standard Features -->
      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="flex items-start space-x-3">
          <svg class="w-6 h-6 text-gaming-purple mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          <div>
            <h4 class="text-white font-semibold mb-1">Instant Setup</h4>
            <p class="text-gray-400 text-sm">Server ready in under 60 seconds</p>
          </div>
        </div>

        <div class="flex items-start space-x-3">
          <svg class="w-6 h-6 text-gaming-purple mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <div>
            <h4 class="text-white font-semibold mb-1">DDoS Protection</h4>
            <p class="text-gray-400 text-sm">Enterprise-grade protection included</p>
          </div>
        </div>

        <div class="flex items-start space-x-3">
          <svg class="w-6 h-6 text-gaming-purple mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          <div>
            <h4 class="text-white font-semibold mb-1">Daily Backups</h4>
            <p class="text-gray-400 text-sm">Never lose your progress</p>
          </div>
        </div>

        <div class="flex items-start space-x-3">
          <svg class="w-6 h-6 text-gaming-purple mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <div>
            <h4 class="text-white font-semibold mb-1">Full Control Panel</h4>
            <p class="text-gray-400 text-sm">Manage everything from web interface</p>
          </div>
        </div>

        <div class="flex items-start space-x-3">
          <svg class="w-6 h-6 text-gaming-purple mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <div>
            <h4 class="text-white font-semibold mb-1">24/7 Support</h4>
            <p class="text-gray-400 text-sm">Expert help when you need it</p>
          </div>
        </div>

        <div class="flex items-start space-x-3">
          <svg class="w-6 h-6 text-gaming-purple mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
          </svg>
          <div>
            <h4 class="text-white font-semibold mb-1">99.9% Uptime</h4>
            <p class="text-gray-400 text-sm">Reliable infrastructure</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-gaming-accent to-gaming-purple">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-5xl font-gaming font-bold text-white mb-6">
        Ready to Start Your {game.name} Server?
      </h2>
      <p class="text-xl text-white/90 mb-8">
        Setup takes less than 60 seconds. No technical knowledge required.
      </p>
      <a href={`https://billing.pocketburrito.ca/order/${game.slug}`} class="inline-block bg-white text-gaming-accent px-10 py-4 rounded-lg text-lg font-bold hover:shadow-2xl hover:scale-105 transition">
        Order Now
      </a>
    </div>
  </section>
</Layout>
