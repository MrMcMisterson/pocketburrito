---
import Layout from '../layouts/Layout.astro';
import { featuredProducts, categories } from '../data/products';
---

<Layout title="Your Pocket-Sized Tech Guide">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 relative">
      <div class="text-center">
        <h1 class="text-4xl sm:text-6xl font-extrabold mb-6">
          <span class="text-white">Your Pocket-Sized</span><br />
          <span class="text-orange-500">Tech Guide</span>
        </h1>
        <p class="text-lg sm:text-xl text-gray-400 mb-8 max-w-2xl mx-auto">
          Handpicked tech deals, honest recommendations, and the gadgets actually worth your money — all in one place.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/deals" class="bg-orange-500 hover:bg-orange-600 text-white px-8 py-3 rounded-lg text-lg font-semibold transition">
            Browse Deals
          </a>
          <a href="/about" class="bg-white/10 text-white px-8 py-3 rounded-lg text-lg font-semibold border border-white/20 hover:bg-white/20 transition">
            Learn More
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="py-16 bg-[#111]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-3">Featured Picks</h2>
        <p class="text-gray-400 text-lg">Our top-rated tech recommendations right now</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredProducts.map((product) => (
          <div class="bg-[#1a1a1a] border border-[#2a2a2a] rounded-xl p-6 hover:border-orange-500/50 transition-all duration-300 group flex flex-col">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs font-medium px-2 py-1 rounded-full bg-orange-500/10 text-orange-400">{product.category}</span>
              <span class="text-xs text-gray-500 ml-auto flex items-center gap-1">
                <svg class="w-3.5 h-3.5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                {product.rating}
              </span>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-orange-400 transition-colors">{product.name}</h3>
            <p class="text-sm text-gray-400 mb-4 flex-1">{product.description}</p>
            <div class="flex items-center justify-between mt-auto">
              <span class="text-xl font-bold text-white">{product.price}</span>
              <a href={product.amazonUrl} target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold rounded-lg transition">
                View Deal &rarr;
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/deals" class="text-orange-400 hover:text-orange-300 font-medium transition">
          View all deals &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white text-center mb-10">Shop by Category</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {categories.map((cat) => (
          <a href={`/deals?category=${cat}`} class="bg-[#1a1a1a] border border-[#2a2a2a] rounded-xl p-6 text-center hover:border-orange-500/50 hover:bg-[#1f1f1f] transition-all group">
            <div class="text-3xl mb-3">
              {cat === 'Gadgets' && '📱'}
              {cat === 'Audio' && '🎧'}
              {cat === 'Smart Home' && '🏠'}
              {cat === 'Accessories' && '⌨️'}
            </div>
            <span class="text-white font-semibold group-hover:text-orange-400 transition-colors">{cat}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-orange-600 to-orange-500">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Never Miss a Deal</h2>
      <p class="text-lg text-white/90 mb-6">Follow us on Twitter for daily tech picks and exclusive finds.</p>
      <a href="https://x.com/TechinSeconds" target="_blank" rel="noopener noreferrer" class="inline-block bg-white text-orange-600 px-8 py-3 rounded-lg text-lg font-bold hover:shadow-xl transition">
        Follow @TechinSeconds
      </a>
    </div>
  </section>
</Layout>
